  "storageAccess": {
    "title": "Why does Scribe ask for folder access?",
    "description": "Explanation of Documents access and .scribe backup files",
    "body1": "Scribe saves documents first to its own in-app database. You can always write and edit — even without access to the Documents folder.",
    "body2": "It also creates backup <strong>.scribe</strong> files in a folder you choose (default <code>~/Documents/Scribe</code>) so you can open them in Finder, back them up, or share them.",
    "body3": "macOS may show a system dialog asking for access to Documents or another location. This is normal — the system protects your files from apps.",
    "body4": "Scribe <strong>does not scan your entire disk</strong>. It only writes to the folder you select. If you deny access, the editor still works and you can change the folder later in Settings → Storage.",
    "pickFolder": "Choose folder"
  },
