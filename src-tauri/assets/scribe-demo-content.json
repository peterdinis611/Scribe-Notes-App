{"type":"doc","content":[{"type":"heading","attrs":{"level":1},"content":[{"type":"text","text":"Sprievodca Scribe — interaktívne demo"}]},{"type":"paragraph","content":[{"type":"text","text":"Tento dokument ukazuje "},{"type":"text","text":"všetky hlavné funkcie","marks":[{"type":"bold"}]},{"type":"text","text":" lokálneho editora Scribe. Prejdite sekciami, skúšajte formátovanie a experimentujte s príkladmi nižšie."}]},{"type":"callout","attrs":{"variant":"tip"},"content":[{"type":"paragraph","content":[{"type":"text","text":"Tip: "},{"type":"text","text":"Začnite napísaním "},{"type":"text","text":"/","marks":[{"type":"code"}]},{"type":"text","text":" v prázdnom riadku — otvorí sa menu slash príkazov s nadpismi, tabuľkami, calloutmi a ďalšími blokmi."}]}]},{"type":"tableOfContents","attrs":{"maxLevel":3}},{"type":"horizontalRule"},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"1. Editor a formátovanie textu"}]},{"type":"paragraph","content":[{"type":"text","text":"Skúste označiť text a použiť toolbar alebo skratky: "},{"type":"text","text":"tučné","marks":[{"type":"bold"}]},{"type":"text","text":", "},{"type":"text","text":"kurzíva","marks":[{"type":"italic"}]},{"type":"text","text":", "},{"type":"text","text":"podčiarknuté","marks":[{"type":"underline"}]},{"type":"text","text":", "},{"type":"text","text":"prečiarknuté","marks":[{"type":"strike"}]},{"type":"text","text":", "},{"type":"text","text":"zvýraznené","marks":[{"type":"highlight"}]},{"type":"text","text":" a "},{"type":"text","text":"inline kód","marks":[{"type":"code"}]},{"type":"text","text":"."}]},{"type":"paragraph","content":[{"type":"text","text":"Farby textu a zarovnanie (vľavo, stred, vpravo, do bloku) nájdete v záložke Text. Odstavec môžete tiež označiť ako citáciu alebo callout."}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"2. Nadpisy a štruktúra"}]},{"type":"heading","attrs":{"level":3},"content":[{"type":"text","text":"Nadpis úrovne 3"}]},{"type":"paragraph","content":[{"type":"text","text":"Pod nadpismi môžete vkladať bežný text, zoznamy aj vnorené bloky. Štruktúru dokumentu zobrazí panel "},{"type":"text","text":"Štruktúra dokumentu","marks":[{"type":"bold"}]},{"type":"text","text":" v pravom paneli (ikona stromu)."}]},{"type":"heading","attrs":{"level":4},"content":[{"type":"text","text":"Nadpis úrovne 4"}]},{"type":"paragraph","content":[{"type":"text","text":"Automatický obsah (TOC) na začiatku tohto dokumentu sa aktualizuje podľa nadpisov."}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"3. Zoznamy a úlohy"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Odrážkový zoznam — vložte cez / alebo toolbar"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Podpora vnorených položiek"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Drag handle vľavo od bloku umožňuje presúvať odsevce"}]}]}]},{"type":"orderedList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Prvý krok"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Druhý krok"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Tretí krok"}]}]}]},{"type":"taskList","content":[{"type":"taskItem","attrs":{"checked":false},"content":[{"type":"paragraph","content":[{"type":"text","text":"Nezaškrtnutá úloha"}]}]},{"type":"taskItem","attrs":{"checked":true},"content":[{"type":"paragraph","content":[{"type":"text","text":"Hotová ukážková úloha"}]}]},{"type":"taskItem","attrs":{"checked":false},"content":[{"type":"paragraph","content":[{"type":"text","text":"Skúste prepnúť checkbox kliknutím"}]}]}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"4. Tabuľka"}]},{"type":"paragraph","content":[{"type":"text","text":"Tabuľky sú editovateľné, s hlavičkou a zmenou šírky stĺpcov."}]},{"type":"table","content":[{"type":"tableRow","content":[{"type":"tableHeader","content":[{"type":"paragraph","content":[{"type":"text","text":"Funkcia"}]}]},{"type":"tableHeader","content":[{"type":"paragraph","content":[{"type":"text","text":"Kde ju nájdete"}]}]},{"type":"tableHeader","content":[{"type":"paragraph","content":[{"type":"text","text":"Skratka"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","content":[{"type":"paragraph","content":[{"type":"text","text":"Nový dokument"}]}]},{"type":"tableCell","content":[{"type":"paragraph","content":[{"type":"text","text":"⌘N alebo tlačidlo +"}]}]},{"type":"tableCell","content":[{"type":"paragraph","content":[{"type":"text","text":"⌘N"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","content":[{"type":"paragraph","content":[{"type":"text","text":"Príkazová paleta"}]}]},{"type":"tableCell","content":[{"type":"paragraph","content":[{"type":"text","text":"⌘K"}]}]},{"type":"tableCell","content":[{"type":"paragraph","content":[{"type":"text","text":"⌘K"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","content":[{"type":"paragraph","content":[{"type":"text","text":"Hľadať v dokumente"}]}]},{"type":"tableCell","content":[{"type":"paragraph","content":[{"type":"text","text":"Lupa v pravom paneli"}]}]},{"type":"tableCell","content":[{"type":"paragraph","content":[{"type":"text","text":"⌘F"}]}]}]},{"type":"tableRow","content":[{"type":"tableCell","content":[{"type":"paragraph","content":[{"type":"text","text":"Režim sústredenia"}]}]},{"type":"tableCell","content":[{"type":"paragraph","content":[{"type":"text","text":"Ikona Focus v paneli"}]}]},{"type":"tableCell","content":[{"type":"paragraph","content":[{"type":"text","text":"⌘⇧F"}]}]}]}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"5. Callout bloky"}]},{"type":"callout","attrs":{"variant":"info"},"content":[{"type":"paragraph","content":[{"type":"text","text":"Info callout — vhodný na vysvetlenie alebo kontext."}]}]},{"type":"callout","attrs":{"variant":"tip"},"content":[{"type":"paragraph","content":[{"type":"text","text":"Tip callout — rady a odporúčania."}]}]},{"type":"callout","attrs":{"variant":"warning"},"content":[{"type":"paragraph","content":[{"type":"text","text":"Varovanie — upozornenie na niečo dôležité."}]}]},{"type":"callout","attrs":{"variant":"danger"},"content":[{"type":"paragraph","content":[{"type":"text","text":"Dôležité — kritická informácia alebo obmedzenie."}]}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"6. Rozbaľovací blok (Details)"}]},{"type":"details","content":[{"type":"detailsSummary","content":[{"type":"text","text":"Kliknite pre rozbalenie ukážky"}]},{"type":"detailsContent","content":[{"type":"paragraph","content":[{"type":"text","text":"Skrytý obsah je užitočný pre FAQ, technické poznámky alebo voliteľné detaily."}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Položka vo vnorenom zozname"}]}]}]}]}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"7. Kód"}]},{"type":"paragraph","content":[{"type":"text","text":"Inline: "},{"type":"text","text":"npm run tauri:dev","marks":[{"type":"code"}]}]},{"type":"codeBlock","attrs":{"language":"typescript"},"content":[{"type":"text","text":"import { createDocument } from '@/lib/db/api'\n\nconst doc = await createDocument({\n  title: 'Môj dokument',\n})\n"}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"8. Matematika (math.js)"}]},{"type":"paragraph","content":[{"type":"text","text":"Vložte vzorec v riadku "},{"type":"mathInline","attrs":{"expression":"2 + 2 * 5"}},{"type":"text","text":" alebo ako blok:"}]},{"type":"mathBlock","attrs":{"expression":"sum = 0\nfor i in 1..10\n  sum = sum + i\nsum"}},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"9. Wiki odkazy medzi dokumentmi"}]},{"type":"paragraph","content":[{"type":"text","text":"Odkaz na iný dokument: "},{"type":"wikiLink","attrs":{"label":"Ukážkový cieľ wiki odkazu","targetId":"{{WIKI_TARGET_ID}}"}},{"type":"text","text":". Napíšte "},{"type":"text","text":"[[názov]]","marks":[{"type":"code"}]},{"type":"text","text":" alebo použite slash príkaz Prepojiť dokument. Pri neexistujúcom cieli Scribe ponúkne vytvorenie nového dokumentu."}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"10. Poznámka pod čiarou"}]},{"type":"paragraph","content":[{"type":"text","text":"Text môže obsahovať referenciu"},{"type":"footnote","attrs":{"id":"demo-fn-1","number":1,"content":"Toto je ukážková poznámka pod čiarou. Kliknite na číslo pre úpravu."}},{"type":"text","text":" ktorá sa zobrazí dole na stránke."}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"11. Komentáre"}]},{"type":"paragraph","content":[{"type":"text","text":"Označte text a vložte komentár cez / alebo panel Komentáre. V tomto deme môžete pridať vlastný komentár k ľubovoľnému odseku — vlákna sa zobrazia v bočnom paneli."}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"12. Obrázky a médiá"}]},{"type":"paragraph","content":[{"type":"text","text":"Pretiahnite obrázok do editora, vložte cez / Obrázok alebo toolbar. Obrázky sa ukladajú do "},{"type":"text","text":"~/Documents/Scribe/assets/","marks":[{"type":"code"}]},{"type":"text","text":". Podporovaný je aj embed YouTube cez URL."}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"13. Knižnica a organizácia"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Priečinky so stromovou štruktúrou a drag & drop"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Fulltextové vyhľadávanie dokumentov (SQLite FTS)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Obľúbené, kôš a nedávne dokumenty"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Presun dokumentu do priečinka z menu súboru"}]}]}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"14. Šablóny a vlastné šablóny"}]},{"type":"paragraph","content":[{"type":"text","text":"⌘N otvorí výber šablón: report, list, životopis, faktúra, esej a ďalšie. Vlastnú šablónu uložíte z aktuálneho dokumentu cez menu súboru. Tento sprievodca je dostupný aj ako šablóna "},{"type":"text","text":"Sprievodca Scribe","marks":[{"type":"bold"}]},{"type":"text","text":"."}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"15. Ukladanie, verzie a synchronizácia"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Auto-save do SQLite (~600 ms po zmene)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Záloha .scribe súborov na disk (Nastavenia → Úložisko)"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"História verzií s porovnaním diff v paneli História"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Ak disk zlyhá, dokument zostane uložený v aplikácii"}]}]}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"16. Export a tlač"}]},{"type":"paragraph","content":[{"type":"text","text":"Exportujte do PDF, DOCX, Markdown, TXT alebo Pages. Náhľad tlače, rozloženie strán, hlavičky/päty a vodotlač nastavíte v menu dokumentu a dialógu Rozloženie strán."}]},{"type":"heading","attrs":{"level":2},"content":[{"type":"text","text":"17. Režimy a panely"}]},{"type":"bulletList","content":[{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Markdown zdroj — prepnite v headeri editora"}]}]},{"type":"listItem","content":[{"type":"paragraph","content":[{"type":"text","text":"Režim sústredenia — skryje